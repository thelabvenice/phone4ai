# Required
PHONE4AI_NUMBER=+14474661303        # Your Phone4.ai number (from account page)
NGROK_AUTHTOKEN=your_ngrok_token    # https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_DOMAIN=your-domain.ngrok-free.dev  # https://dashboard.ngrok.com/domains

# Optional — ElevenLabs TTS (falls back to Twilio TTS without these)
ELEVENLABS_API_KEY=your_key         # https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_VOICE_ID=your_voice_id   # https://elevenlabs.io/app/voice-library

# Optional — Advanced
PHONE4AI_API=https://api.phone4.ai  # API endpoint (default)
PHONE_WEBHOOK_PORT=7600             # Webhook port (default)
